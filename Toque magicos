<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Toque Mágico</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:linear-gradient(180deg,#fff,#ffe6f0);
color:#d63384;
text-align:center;
overflow-x:hidden;
}

header{
padding:40px 20px;
background:#ff69b4;
color:white;
box-shadow:0 5px 15px rgba(0,0,0,.2);
}

header h1{
font-size:42px;
}

header p{
margin-top:10px;
font-size:18px;
}

.container{
padding:40px 20px;
}

.card{
background:white;
max-width:500px;
margin:auto;
padding:30px;
border-radius:20px;
box-shadow:0 10px 20px rgba(0,0,0,.15);
}

.card h2{
margin-bottom:15px;
}

.btn{
display:block;
margin:15px auto;
width:90%;
padding:16px;
border-radius:50px;
text-decoration:none;
font-size:18px;
font-weight:bold;
transition:.3s;
}

.whatsapp{
background:#25D366;
color:white;
}

.whatsapp:hover{
background:#1da851;
}

.instagram{
background:#E1306C;
color:white;
}

.instagram:hover{
background:#c61b5d;
}

.flor{
position:fixed;
font-size:35px;
opacity:.2;
animation:flutuar 8s infinite linear;
}

.f1{top:5%;left:5%;}
.f2{top:15%;right:8%;}
.f3{bottom:10%;left:10%;}
.f4{bottom:15%;right:5%;}
.f5{top:45%;left:2%;}

@keyframes flutuar{
0%{transform:translateY(0px) rotate(0deg);}
50%{transform:translateY(-15px) rotate(10deg);}
100%{transform:translateY(0px) rotate(0deg);}
}

footer{
margin-top:40px;
padding:20px;
background:#ffb6c1;
color:#fff;
font-weight:bold;
}
</style>

</head>
<body>

<div class="flor f1">🌸</div>
<div class="flor f2">🌷</div>
<div class="flor f3">🌺</div>
<div class="flor f4">🌸</div>
<div class="flor f5">🌹</div>

<header>
<h1>🌸 Toque Mágico 🌸</h1>
<p>Lingeries com charme, beleza e delicadeza.</p>
</header>

<div class="container">

<div class="card">

<h2>Entre em contato</h2>

<a class="btn whatsapp"
href="https://wa.me/5511943374143"
target="_blank">
📱 WhatsApp
</a>

<a class="btn instagram"
href="https://www.instagram.com/toque.magicolingerie?igsh=MXNsdWhodGk5dWd6ZQ=="
target="_blank">
📷 Instagram
</a>

</div>

</div>

<footer>
© 2026 • Toque Mágico
</footer>

</body>
</html>
