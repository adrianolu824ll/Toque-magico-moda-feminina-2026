<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:linear-gradient(180deg,#fff0f6,#ffd6e7);
    color:#e91e63;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
    position:relative;
}

/* Flores */
.flor{
    position:absolute;
    font-size:40px;
    opacity:.15;
    animation:flutuar 6s ease-in-out infinite;
}

.f1{top:5%;left:5%;}
.f2{top:10%;right:8%;}
.f3{bottom:10%;left:8%;}
.f4{bottom:8%;right:6%;}
.f5{top:50%;left:2%;}
.f6{top:50%;right:2%;}

@keyframes flutuar{
    0%,100%{transform:translateY(0);}
    50%{transform:translateY(-15px);}
}

.card{
    background:#fff;
    width:90%;
    max-width:550px;
    padding:40px;
    border-radius:25px;
    text-align:center;
    box-shadow:0 10px 30px rgba(233,30,99,.25);
    border:3px solid #ffb6c1;
}

.logo{
    font-size:60px;
}

h1{
    font-size:32px;
    margin-top:10px;
}

p{
    margin:15px 0 30px;
    color:#666;
}

.btn{
    display:block;
    text-decoration:none;
    color:#fff;
    padding:16px;
    margin:15px 0;
    border-radius:50px;
    font-size:18px;
    font-weight:bold;
    transition:.3s;
}

.whatsapp{
    background:#25D366;
}

.instagram{
    background:linear-gradient(45deg,#833AB4,#E1306C,#F77737);
}

.btn:hover{
    transform:scale(1.03);
}

footer{
    margin-top:25px;
    color:#e91e63;
    font-size:14px;
}
</style>

</head>
<body>

<div class="flor f1">🌸</div>
<div class="flor f2">🌷</div>
<div class="flor f3">🌺</div>
<div class="flor f4">🌼</div>
<div class="flor f5">🌹</div>
